# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
# 64-char random hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=CHANGE_ME_GENERATE_RANDOM_64_HEX

# Max age of a signed request in seconds (anti-replay)
REQUEST_TIMESTAMP_WINDOW_SECS=300

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DB_PATH=./data/vouchers.db

# ─────────────────────────────────────────────
# MikroTik Router
# ─────────────────────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASS=CHANGE_ME
MIKROTIK_HOTSPOT_SERVER=hotspot1

# ─────────────────────────────────────────────
# Africa's Talking (SMS delivery)
# ─────────────────────────────────────────────
AT_API_KEY=CHANGE_ME
AT_USERNAME=sandbox
AT_SENDER_ID=VoucherSMS

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
ADMIN_TOKEN=CHANGE_ME_GENERATE_RANDOM_64_HEX

# ─────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
